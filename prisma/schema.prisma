generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SectionType {
  SUMMARY
  SKILLS
  EDUCATION
  WORK_EXPERIENCE
  OTHER_FIELD
  HEADER
  PROJECT
  CERTIFICATION
  AWARD
}

enum BorderStyle {
  SQUIRCLE
  ROUNDED
  SQUARE
}

enum SkillCategory {
  TECHNICAL
  SOFT
  OTHER
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Resume {
  id              String           @id @default(cuid())
  userId          String
  title           String?
  description     String?
  photoUrl        String?
  colorHex        String           @default("default")
  template      String           @default("aurora")
  borderStyle     BorderStyle      @default(SQUIRCLE)
  atsScore        Int?              @default(0)
  summary         String?
  firstName       String?
  lastName        String?
  jobTitle        String?
  jobDescription  String?
  city            String?
  country         String?
  phone           String?
  email           String?
  links           Link[]
  educations      Education[]
  workExperiences WorkExperience[]
  otherFields     OtherField[]
  sections        Section[]
  skills          Skill[]
  projects        Project[]
  certifications  Certification[]
  awards          Award[]
  

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("resumes")
}

model Link {
  id        String   @id @default(cuid())
  name      String
  url       String
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("links")
}

model Section {
  id String @id @default(cuid())

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  sectionType SectionType
  order       Int

  enabled Boolean @default(true)
  icon String @default("star")

  title String
  description String @default("")
  sidebarDescription String @default("")

  otherFieldId String?     @unique
  otherField   OtherField? @relation(fields: [otherFieldId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("sections")
}

model WorkExperience {
  id          String    @id @default(cuid())
  position    String?
  company     String?
  city        String?
  country     String?
  isCurrent   Boolean   @default(false)
  startDate   DateTime?
  endDate     DateTime?
  description String?
  resumeId    String
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  order       Int       @default(0)

  @@index([resumeId])
  @@map("work_experiences")
}

model Education {
  id          String  @id @default(cuid())
  degree      String?
  school      String?
  description String?
  

  isCurrent Boolean   @default(false)
  startDate DateTime?
  endDate   DateTime?

  city    String?
  country String?

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  order Int @default(0)

  @@index([resumeId])
  @@map("educations")
}

model Skill {
  id   String @id @default(cuid())
  name String

  level    SkillLevel    @default(BEGINNER)
  category SkillCategory @default(TECHNICAL)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  order Int @default(0)

  // @@unique([resumeId, name])
  @@index([resumeId])
  @@map("skills")
}

model OtherField {
  id String @id @default(cuid())

  title       String?
  subtitle    String?
  description String?

  startDate DateTime?
  endDate   DateTime?

  order Int @default(0)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  section Section?

  @@index([resumeId])
  @@map("other_fields")
}

model Project {
  id          String    @id @default(cuid())
  title       String?
  description String?
  url         String?
  startDate   DateTime?
  endDate     DateTime?
  order       Int       @default(0)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("projects")
}

model Certification {
  id            String    @id @default(cuid())
  name          String?
  issuer        String?
  issueDate     DateTime?
  expiryDate    DateTime?
  credentialUrl String?
  order         Int       @default(0)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("certifications")
}

model Award {
  id          String    @id @default(cuid())
  title       String?
  issuer      String?
  date        DateTime?
  description String?
  order       Int       @default(0)

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("awards")
}

model Subscription {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  stripeCustomerId        String   @unique
  stripeSubscriptionId    String   @unique
  stripePriceId           String
  stripeCurrentPeriodEnd  DateTime
  stripeCancelAtPeriodEnd Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
  @@map("user_subscriptions")
}
